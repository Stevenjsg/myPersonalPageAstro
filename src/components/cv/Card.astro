---
interface Props {
  class?: string;
  featured?: boolean;
}
const { class: className = "", featured = false } = Astro.props;
---

<div
  class:list={[
    "bg-[var(--surface)] border border-[var(--border)] rounded-2xl shadow-[var(--shadow-1)]",
    "transition-[transform,box-shadow,border-color] duration-300 ease-[cubic-bezier(.16,1,.3,1)]",
    "hover:-translate-y-0.5 hover:shadow-[var(--shadow-2)]",
    "hover:border-ink-300 dark:hover:border-sunglow-700",
    featured && "ring-1 ring-sunglow-500/20",
    className,
  ]}
>
  <slot />
</div>
