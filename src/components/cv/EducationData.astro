---
import Card from "./Card.astro";
import type { Education } from "../../data/dataTypes";

interface Props {
  education: Education[];
}
const { education } = Astro.props;
---

<section class="mb-12 last:mb-0">
  <div class="flex items-end justify-between mb-5">
    <div>
      <span
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]"
      >
        · Formación
      </span>
      <h2 class="text-2xl font-extrabold tracking-[-0.02em] mt-1.5">
        Educación
      </h2>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {
      education.map((edu: Education) => (
        <Card class="p-6 flex gap-4">
          <span class="flex-none inline-flex items-center justify-center w-11 h-11 rounded-xl bg-[var(--surface-2)] text-[var(--text-2)] dark:text-sunglow-500">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 9 12 4 2 9l10 5 10-5Z" />
              <path d="M6 11v5c0 1.5 2.7 3 6 3s6-1.5 6-3v-5" />
            </svg>
          </span>
          <div>
            <span class="font-mono text-[11px] text-[var(--kicker)]">
              {edu.startDate} — {edu.endDate}
            </span>
            {edu.status && (
              <span class="inline-flex items-center gap-1 ml-2 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-[var(--color-emerald-accent)]/15 text-[var(--color-emerald-text)] dark:text-emerald-400">
                <i class="block w-1 h-1 rounded-full bg-[var(--color-emerald-accent)]" />
                {edu.status}
              </span>
            )}
            <h3 class="text-[15px] font-bold leading-tight mt-1">
              {edu.institution}
            </h3>
            <p class="text-[13px] text-[var(--text-2)] mt-0.5">
              {edu.studyType}
            </p>
            {edu.note && (
              <p class="font-mono text-[12px] text-[var(--kicker)] mt-1.5">
                {edu.note}
              </p>
            )}
          </div>
        </Card>
      ))
    }
  </div>
</section>
