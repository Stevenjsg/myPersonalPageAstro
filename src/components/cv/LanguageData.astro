---
import Card from "./Card.astro";
import type { Language } from "../../data/dataTypes";

interface Props {
  languages: Language[];
}
const { languages } = Astro.props;
---

<Card class="p-6">
  <div class="flex items-center gap-2.5 mb-4">
    <span
      class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-[var(--surface-2)] text-[var(--text-2)] dark:text-sunglow-500"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path
          d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z"
        ></path>
      </svg>
    </span>
    <span
      class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]"
    >
      · Idiomas
    </span>
  </div>

  {
    languages.map((lang: Language) => (
      <div class="mb-4 last:mb-0">
        <div class="flex items-baseline justify-between mb-1.5">
          <span class="text-[13px] font-semibold">{lang.language}</span>
          <span class="font-mono text-[11px] text-[var(--kicker)]">
            {lang.fluency}
          </span>
        </div>
        <div class="h-1.5 rounded-full bg-[var(--surface-2)] overflow-hidden">
          <span
            class="block h-full rounded-full bg-[var(--accent)]"
            style={`width:${lang.level ?? 0}%`}
          />
        </div>
      </div>
    ))
  }
</Card>
