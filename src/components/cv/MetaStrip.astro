---
interface Props {
  left?: string;
  right: string;
  backUrl?: string;
  backLabel?: string;
}
const {
  left,
  right,
  backUrl,
  backLabel = "Volver",
} = Astro.props;
---

<div class="flex items-center justify-between gap-4 mb-10">
  {
    backUrl ? (
      <a
        href={backUrl}
        class="group inline-flex items-center gap-1.5 font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)] no-underline transition-colors duration-200 hover:text-[var(--text)] dark:hover:text-sunglow-500"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-200 group-hover:-translate-x-0.5"
        >
          <path d="M19 12H5" />
          <path d="m12 19-7-7 7-7" />
        </svg>
        {backLabel}
      </a>
    ) : (
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]">
        {left}
      </span>
    )
  }
  <span
    class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]"
  >
    {right}
  </span>
</div>
