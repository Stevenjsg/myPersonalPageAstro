---
import Card from "./Card.astro";
import type { Basics, Profile } from "../../data/dataTypes";

interface Props {
  basics: Basics;
}
const { basics } = Astro.props;
const { profiles } = basics;

const socialPath: Record<string, string> = {
  GitHub:
    "M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.12 3.05.73.8 1.18 1.82 1.18 3.08 0 4.42-2.7 5.39-5.27 5.68.42.36.79 1.06.79 2.13v3.16c0 .31.21.66.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z",
  LinkedIn:
    "M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 9.5h4V21H3V9.5Zm6.5 0h3.83v1.57h.06c.53-1 1.84-2.06 3.79-2.06 4.05 0 4.8 2.67 4.8 6.13V21h-4v-5.13c0-1.22-.02-2.79-1.7-2.79-1.71 0-1.98 1.34-1.98 2.7V21h-4V9.5Z",
  X: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.83l4.713 6.231 5.447-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z",
};
---

<Card class="p-8">
  <div class="flex flex-wrap gap-7">
    <!-- FOTO -->
    <div class="flex-none flex flex-col items-center gap-3">
      <div
        class="relative w-[132px] h-[160px] rounded-3xl overflow-hidden bg-[var(--surface-2)] shadow-[inset_0_0_0_1px_var(--border),var(--shadow-1)] grid place-items-center"
      >
        <img
          src={basics.image}
          alt={`Foto de perfil de ${basics.name}`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <span
          class="absolute -bottom-2 -right-2 w-5 h-5 rounded-full bg-sunglow-500 shadow-[0_0_0_4px_var(--surface)]"
        ></span>
      </div>
      {
        basics.available && (
          <span class="inline-flex items-center gap-1.5 font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--color-emerald-text)] dark:text-emerald-400">
            <span class="relative inline-flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-[var(--color-emerald-accent)]" />
              <span class="absolute inset-0 rounded-full bg-[var(--color-emerald-accent)] pulse-ping" />
            </span>
            Disponible
          </span>
        )
      }
    </div>

    <!-- BODY -->
    <div class="flex-1 min-w-0 basis-80">
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]">
        · Curriculum
      </span>
      <h1
        class="mt-2 font-extrabold leading-[1.05] tracking-[-0.02em] text-[clamp(1.6rem,3vw,2.1rem)]"
      >
        {basics.name}
      </h1>
      <div
        class="inline-flex items-center gap-2 mt-1.5 text-sm font-semibold text-[var(--text-2)] dark:text-sunglow-500"
      >
        <span class="block w-5 h-px bg-sunglow-500"></span>
        {basics.label}
      </div>
      <p class="mt-4 text-sm leading-[1.65] text-[var(--text-2)] max-w-[42rem] text-pretty">
        {basics.summary}
      </p>

      <!-- META ROW -->
      <div class="flex flex-wrap items-center gap-3 mt-6 text-[13px] text-[var(--text-2)]">
        <span class="inline-flex items-center gap-1.5">
          <span class="text-[var(--text-mute)] dark:text-sunglow-600 inline-flex">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </span>
          {basics.location.city}, {basics.location.countryCode}
        </span>
        <span class="block w-1 h-1 rounded-full bg-[var(--border)]"></span>
        <a
          href={`mailto:${basics.email}`}
          class="inline-flex items-center gap-1.5 hover:underline"
        >
          <span class="text-[var(--text-mute)] dark:text-sunglow-600 inline-flex">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" />
            </svg>
          </span>
          {basics.email}
        </a>
      </div>

      <!-- ACTIONS -->
      <div class="flex flex-wrap items-center gap-3 mt-5">
        {
          basics.cvUrl ? (
            <a
              href={basics.cvUrl}
              download
              class="group inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold no-underline bg-[var(--accent)] text-[var(--accent-text)] shadow-[var(--shadow-1)] transition-all duration-200 hover:shadow-[var(--shadow-2)] hover:bg-ink-700 dark:hover:bg-sunglow-400"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-200 group-hover:translate-y-0.5"
              >
                <path d="M12 3v12M7 11l5 5 5-5" />
                <path d="M4 19h16" />
              </svg>
              Descargar CV
            </a>
          ) : (
            <button
              type="button"
              disabled
              aria-disabled="true"
              title="Próximamente"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-[var(--surface-2)] text-[var(--text-mute)] cursor-not-allowed opacity-60"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 3v12M7 11l5 5 5-5" />
                <path d="M4 19h16" />
              </svg>
              Descargar CV
            </button>
          )
        }
        <div class="inline-flex gap-1.5">
          {
            profiles.map((profile: Profile) => (
              <a
                href={profile.url}
                target="_blank"
                rel="noopener"
                aria-label={profile.network}
                class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--border)] text-[var(--text-2)] dark:text-sunglow-500 transition-all duration-200 hover:bg-[var(--accent)] hover:text-[var(--accent-text)] hover:border-transparent"
              >
                <svg
                  width={profile.network === "X" ? "15" : "17"}
                  height={profile.network === "X" ? "15" : "17"}
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d={socialPath[profile.network] ?? ""} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Card>
