---
import Card from "./Card.astro";
import type { Project } from "../../data/dataTypes";

interface Props {
  projects: Project[];
}
const { projects } = Astro.props;
---

<section class="mb-12 last:mb-0">
  <div class="flex items-end justify-between mb-5">
    <div>
      <span
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]"
      >
        · Trabajo seleccionado
      </span>
      <h2 class="text-2xl font-extrabold tracking-[-0.02em] mt-1.5">
        Proyectos
      </h2>
    </div>
    <span class="font-mono text-[12px] text-[var(--kicker)]">
      <b class="text-[var(--accent)] text-base">{projects.length}</b> total
    </span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 items-stretch">
    {
      projects.map((project: Project) => {
        const targetUrl = project.url || project.repository || "#";
        return (
          <Card class="group p-6 flex flex-col" featured={project.featured}>
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-base font-extrabold tracking-[-0.01em] leading-[1.15] m-0">
                  {project.name}
                </h3>
                {project.tag && (
                  <div class="font-mono text-[11px] tracking-[0.15em] uppercase text-sunglow-400 dark:text-sunglow-600 mt-1">
                    {project.tag}
                  </div>
                )}
              </div>
              <a
                href={targetUrl}
                target="_blank"
                rel="noopener"
                aria-label={`Abrir ${project.name}`}
                class="flex-none inline-flex items-center justify-center w-9 h-9 rounded-full border border-[var(--border)] text-[var(--text-mute)] dark:text-sunglow-600 transition-all duration-200 group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-text)] group-hover:border-transparent"
              >
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17 17 7" />
                  <path d="M8 7h9v9" />
                </svg>
              </a>
            </div>

            <p class="text-[13px] leading-[1.6] text-[var(--text-2)] mt-3">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-1.5 mt-4">
              {project.accentKeywords?.map((kw: string) => (
                <span class="inline-flex items-center px-2.5 py-1 rounded-md font-mono text-[11px] bg-sunglow-500/15 text-sunglow-400 dark:text-sunglow-500">
                  {kw}
                </span>
              ))}
              {project.keywords?.map((kw: string) => (
                <span class="inline-flex items-center px-2.5 py-1 rounded-md font-mono text-[11px] bg-[var(--chip-bg)] text-[var(--chip-text)]">
                  {kw}
                </span>
              ))}
            </div>

            {!!project.highlights?.length && (
              <ul class="list-none p-0 mt-4 flex-1 space-y-2">
                {project.highlights.map((item: string) => (
                  <li class="flex gap-2 text-[12.5px] leading-[1.6] text-[var(--text-2)]">
                    <span class="flex-none mt-[7px] w-1 h-1 rounded-full bg-sunglow-500" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}

            <a
              href={project.repository || targetUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 mt-5 text-[12px] font-semibold no-underline text-[var(--text-2)] dark:text-sunglow-600 group-hover:text-[var(--text)] dark:group-hover:text-sunglow-500"
            >
              Ver código
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M7 17 17 7" />
                <path d="M8 7h9v9" />
              </svg>
            </a>
          </Card>
        );
      })
    }
  </div>
</section>
