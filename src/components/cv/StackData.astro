---
import Card from "./Card.astro";
import type { SkillGroup, SkillItem } from "../../data/dataTypes";

interface Props {
  skillGroups: SkillGroup[];
}
const { skillGroups } = Astro.props;
const MAX_DOTS = 4;
---

<Card class="p-7 h-full">
  <div class="flex items-center gap-2.5 mb-6">
    <span
      class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-[var(--surface-2)] text-[var(--text-2)] dark:text-sunglow-500"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m12 3 9 5-9 5-9-5 9-5Z"></path>
        <path d="m3 13 9 5 9-5M3 17l9 5 9-5" opacity="0.6"></path>
      </svg>
    </span>
    <div>
      <span
        class="font-mono text-[11px] tracking-[0.25em] uppercase text-[var(--kicker)]"
      >
        · Stack
      </span>
      <div class="text-base font-extrabold tracking-[-0.01em] mt-0.5">
        Habilidades
      </div>
    </div>
  </div>

  {
    skillGroups.map((group: SkillGroup) => (
      <div class="mb-6 last:mb-0">
        <div class="font-mono text-[11px] tracking-[0.15em] uppercase text-[var(--text-mute)] dark:text-sunglow-700 mb-2.5">
          {group.name}
        </div>
        {group.items.map((skill: SkillItem) => (
          <div class="flex items-center justify-between gap-3 px-3 py-1.5 rounded-lg bg-[var(--surface-3)] border border-[var(--border-soft)] mb-2 last:mb-0">
            <span class="text-[13px] font-medium whitespace-nowrap">
              {skill.name}
            </span>
            <span class="inline-flex gap-1">
              {Array.from({ length: MAX_DOTS }).map((_, i) => (
                <i
                  class:list={[
                    "block w-1.5 h-1.5 rounded-full",
                    i < skill.score
                      ? "bg-[var(--accent)]"
                      : "bg-ink-200 dark:bg-ink-700",
                  ]}
                />
              ))}
            </span>
          </div>
        ))}
      </div>
    ))
  }
</Card>
