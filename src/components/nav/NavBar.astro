---
import LogoMark from "./LogoMark.astro";
import ThemePillToggle from "./ThemePillToggle.astro";

// La URL pública de la página Next.js (raíz del dominio). Los links de
// navegación apuntan al padre; `/cv` se queda en este Astro app.
const HOME = "/";

// Estado activo: este Astro app vive bajo /cv, así que "CV" siempre es la
// pestaña activa para cualquier ruta servida desde aquí.
const activeKey = "cv";

type NavItem = { key: string; href: string; label: string; icon: string };

const items: NavItem[] = [
  {
    key: "home",
    href: HOME,
    label: "Home",
    icon: `<path d="M3 11l9-8 9 8" /><path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10" />`,
  },
  {
    key: "posts",
    href: "/posts",
    label: "Posts",
    icon: `<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" /><path d="M14 3v5h5" /><path d="M9 13h6M9 17h4" />`,
  },
  {
    key: "cv",
    href: "/cv",
    label: "CV",
    icon: `<rect x="3" y="7" width="18" height="13" rx="2" /><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /><path d="M3 13h18" />`,
  },
  {
    key: "profile",
    href: "/profile",
    label: "Perfil",
    icon: `<circle cx="12" cy="12" r="9" /><circle cx="12" cy="10" r="3.2" /><path d="M5.6 19c1.2-2.8 3.6-4.2 6.4-4.2s5.2 1.4 6.4 4.2" />`,
  },
];
---

<header
  class="sticky top-0 z-40 border-b border-ink-200/60 bg-white/75 backdrop-blur-md dark:border-sunglow-100/40 dark:bg-ink-950/75 print:hidden"
>
  <div
    class="mx-auto flex h-16 max-w-[1380px] items-center justify-between gap-2 px-3 sm:gap-4 sm:px-8"
  >
    <!-- Izquierda: logo -->
    <div class="flex items-center">
      <LogoMark href={HOME} />
    </div>

    <!-- Centro: nav -->
    <nav
      class="flex flex-1 items-center justify-center gap-0.5 sm:flex-none sm:gap-2"
    >
      {
        items.map((item) => {
          const isActive = item.key === activeKey;
          const cls = [
            "group flex flex-col items-center gap-0.5 px-2 py-1.5 transition-colors sm:px-3",
            isActive
              ? "text-ink-900 dark:text-sunglow-500"
              : "text-ink-500 hover:text-ink-900 dark:text-ink-400 dark:hover:text-sunglow-600",
          ].join(" ");
          return (
            <a class={cls} href={item.href} aria-current={isActive ? "page" : undefined}>
              <span class="transition-transform group-hover:-translate-y-0.5">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={item.icon}
                />
              </span>
              <span class="hidden text-[11px] font-medium tracking-wide sm:inline">
                {item.label}
              </span>
            </a>
          );
        })
      }
    </nav>

    <!-- Derecha: auth + theme -->
    <div class="flex items-center justify-end gap-2 sm:gap-5">
      <!-- Auth states. La visibilidad de cada uno depende de `html[data-session]`
           que es seteado por el script inline de session-init antes del paint. -->
      <a
        data-auth-out
        href="/login"
        class="hidden text-sm font-medium text-ink-700 transition-colors hover:text-ink-900 dark:text-sunglow-600 dark:hover:text-sunglow-500"
      >
        Iniciar sesión
      </a>
      <button
        data-auth-in
        data-logout-btn
        type="button"
        class="hidden text-sm font-medium text-ink-700 transition-colors hover:text-ink-900 disabled:opacity-50 dark:text-sunglow-600 dark:hover:text-sunglow-500"
      >
        Cerrar sesión
      </button>

      <ThemePillToggle />
    </div>
  </div>
</header>

<style is:global>
  /* Visibilidad de los estados de sesión. La cookie `hasSession` (set
     por Next.js en /api/login y limpiado por /api/logout) decide cuál
     se muestra. El init script aplica data-session=in|out en <html>
     antes del paint para evitar flicker.

     Solo desktop (>=640px): en mobile mantenemos ambos ocultos. */
  @media (min-width: 640px) {
    html[data-session="in"] [data-auth-in] {
      display: inline;
    }
    html[data-session="out"] [data-auth-out] {
      display: inline;
    }
  }
</style>

<script is:inline>
  // === NAV INIT — corre antes del paint =====================================
  (function () {
    var cookies = document.cookie.split("; ");
    function getCookie(name) {
      var match = cookies.find(function (c) {
        return c.indexOf(name + "=") === 0;
      });
      return match ? decodeURIComponent(match.split("=")[1]) : "";
    }

    // Tema: respeta cookie 'theme' compartida con Next.js. Fallback a
    // prefers-color-scheme si no hay cookie.
    var theme = getCookie("theme");
    if (!theme) {
      theme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }
    document.documentElement.classList.toggle("dark", theme === "dark");

    // Sesión: cookie hint no-httpOnly puesta por Next.js.
    var hasSession = getCookie("hasSession") === "1";
    document.documentElement.dataset.session = hasSession ? "in" : "out";
  })();
</script>

<script>
  // === INTERACTIVIDAD (post-hidratación) ====================================

  // Theme toggle — escribe la cookie `theme` (compartida con Next.js) y
  // togglea la clase `.dark` en <html>.
  document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      const value = isDark ? "dark" : "light";
      const maxAge = 60 * 60 * 24 * 365;
      document.cookie = `theme=${value}; path=/; max-age=${maxAge}; SameSite=Lax`;
    });
  });

  // Logout — POST a /api/logout (Next.js). El endpoint limpia las cookies y
  // redirige a "/". Al ser mismo dominio, las cookies se envían automáticamente.
  document.querySelectorAll<HTMLButtonElement>("[data-logout-btn]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      if (btn.disabled) return;
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = "Cerrando…";
      try {
        const res = await fetch("/api/logout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
        });
        if (res.redirected) {
          window.location.href = res.url;
          return;
        }
        // Si no redirige, actualizamos el estado a out localmente.
        document.documentElement.dataset.session = "out";
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  });
</script>
