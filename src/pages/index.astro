---
import CV from "../data/mockedCV.json";
import NavBar from "../components/nav/NavBar.astro";
import PersonalData from "../components/cv/PersonalData.astro";
import AvailabilityData from "../components/cv/AvailabilityData.astro";
import LanguageData from "../components/cv/LanguageData.astro";
import StackData from "../components/cv/StackData.astro";
import EducationData from "../components/cv/EducationData.astro";
import ProjectsData from "../components/cv/ProjectsData.astro";
import MetaStrip from "../components/cv/MetaStrip.astro";
import EndAccent from "../components/cv/EndAccent.astro";

import "../styles/global.css";

import type { CvMockup } from "../data/dataTypes";

const cvData = CV as unknown as CvMockup;
const {
  basics,
  availability,
  education,
  skillGroups,
  projects,
  languages,
} = cvData;

const year = new Date().getFullYear();
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={`CV de ${basics.name} — ${basics.label}. ${basics.location.city}, ${basics.location.countryCode}.`}
    />
    <title>CV · {basics.name}</title>
  </head>
  <body class="font-sans">
    <NavBar />

    <main class="max-w-[1100px] mx-auto px-5 sm:px-8 pt-10 sm:pt-12 pb-18 sm:pb-24">
      <MetaStrip
        backUrl="/"
        backLabel="Volver"
        right={`${basics.location.city}, ${basics.location.countryCode} · ${year}`}
      />

      <!-- BENTO TOP -->
      <section class="grid grid-cols-1 md:grid-cols-6 gap-4 mb-12">
        <!-- LEFT COLUMN -->
        <div class="md:col-span-4 grid gap-4 content-start">
          <PersonalData basics={basics} />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <AvailabilityData availability={availability} />
            <LanguageData languages={languages} />
          </div>
        </div>

        <!-- RIGHT COLUMN — Skills -->
        <div class="md:col-span-2">
          <StackData skillGroups={skillGroups} />
        </div>
      </section>

      <EducationData education={education} />
      <ProjectsData projects={projects} />

      <EndAccent />
    </main>
  </body>
</html>

<style>
  body {
    position: relative;
    min-height: 100dvh;
  }
</style>
